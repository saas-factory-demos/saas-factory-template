# Worktree: lp
# 開發 port 配置
TEMPLATE_PORT=3070
FACTORY_PORT=3071
NEXT_PUBLIC_TEMPLATE_PORT=3070
NEXT_PUBLIC_FACTORY_PORT=3071

# DB（建議每個 worktree 用獨立 DB 名）
DATABASE_URI=postgres://postgres:postgres@localhost:5432/saas_factory_lp

# Payload
PAYLOAD_SECRET=change-me-in-production-lp
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3070

# Email (Resend)
RESEND_API_KEY=

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Video (Bunny.net)
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_CDN_HOSTNAME=

# Payment (測試用，依 worktree 需求設定)
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# Invoice
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=
