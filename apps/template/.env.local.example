# 應用基本
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS
PAYLOAD_SECRET=dev-secret-change-me-please

# PostgreSQL（與根目錄 docker-compose.yml 對應）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/saas_factory_bootstrap

# --- Sentry self-hosted（未設 NEXT_PUBLIC_SENTRY_DSN 時 SDK 整段 no-op）---
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@openclaw-media-vm.tail4b24a0.ts.net/<project-id>
# SENTRY_URL=https://openclaw-media-vm.tail4b24a0.ts.net
# SENTRY_ORG=saas-factory
# SENTRY_PROJECT=<client-subdomain>
# SENTRY_AUTH_TOKEN=sntrys_xxx   # build-time sourcemap upload only (scope: project:releases)
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
# SENTRY_CSP_CONNECT_SRC=https://extra-host.example.com   # 額外 connect-src 允許（多筆以空白分隔）
