{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Root E2E config（only covers playwright.config.ts + tests/）",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["playwright.config.ts", "tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "apps", "packages", "dist", ".next", ".turbo"]
}
